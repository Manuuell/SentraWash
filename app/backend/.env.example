# ===== App =====
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ===== Base de datos (PostgreSQL) =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentrawash
# La API se conecta con un rol de MÍNIMO PRIVILEGIO (no superusuario): es lo que
# permite que Row-Level Security aísle por tenant. Lo crea docker/init/01-init-app-role.sql.
DB_USERNAME=sentrawash_app
DB_PASSWORD=sentrawash_app
# Credenciales administrativas (dueño del esquema) usadas SOLO por migraciones/seed.
DB_ADMIN_USERNAME=sentrawash
DB_ADMIN_PASSWORD=sentrawash
DB_SSL=false
# Pone false en prod: el esquema se gestiona SOLO con migraciones
DB_SYNCHRONIZE=false
DB_LOGGING=true

# ===== Multi-tenancy =====
# En dev se puede resolver el tenant por header (x-tenant-id).
# En prod el tenant viaja dentro del JWT de Cognito (custom:tenant_id).
TENANT_HEADER=x-tenant-id
ALLOW_HEADER_TENANT=true

# ===== Auth (Amazon Cognito) =====
# Region y User Pool del entorno; se usan para validar el JWT vía JWKS.
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Claim del JWT que contiene el tenant y los roles
JWT_TENANT_CLAIM=custom:tenant_id
JWT_ROLES_CLAIM=cognito:groups
# En dev se puede desactivar la verificación de firma para probar sin Cognito
AUTH_ENABLED=false

# ===== WhatsApp Cloud API (Meta) =====
# Token de verificación del webhook (lo configuras igual en el panel de Meta).
WHATSAPP_VERIFY_TOKEN=sentrawash-verify
# Token de acceso para enviar mensajes. Si está vacío, los envíos se SIMULAN (log).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_VERSION=v21.0
# Número emisor por defecto (fallback); normalmente se resuelve por tenant.
WHATSAPP_PHONE_NUMBER_ID=
