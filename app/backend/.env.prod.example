# ============================================================================
# Plantilla de entorno para PRODUCCIÓN (VPS). Copiar a `.env.prod` y editar.
#   cp .env.prod.example .env.prod
# NUNCA subas `.env.prod` a git (ya está en .gitignore).
# ============================================================================

# ===== App =====
NODE_ENV=production
PORT=3000
API_PREFIX=api/v1

# ===== Base de datos (Postgres en contenedor, red interna) =====
# DB_HOST lo fija docker-compose.prod.yml (= db). No lo pongas aquí.
DB_PORT=5432
DB_NAME=sentrawash

# Rol de la app (mínimo privilegio, lo crea docker/init/01-init-app-role.sql).
DB_USERNAME=sentrawash_app
DB_PASSWORD=sentrawash_app

# Rol administrador (dueño del esquema) — usado por migraciones/seed Y por el
# contenedor de Postgres (POSTGRES_USER/PASSWORD). CAMBIA esta contraseña.
DB_ADMIN_USERNAME=sentrawash
DB_ADMIN_PASSWORD=CAMBIA_ESTA_CLAVE_admin_larga

DB_SSL=false
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ===== Multi-tenancy =====
TENANT_HEADER=x-tenant-id
# En esta fase el tenant viaja por header. Cuando actives Cognito, pon false.
ALLOW_HEADER_TENANT=true

# ===== Auth (Cognito) =====
# ⚠️ Mientras esté en false, la API NO valida identidad. Aceptable solo para
#    demo controlada. Antes de datos reales: configurar Cognito y poner true.
AUTH_ENABLED=false
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
JWT_TENANT_CLAIM=custom:tenant_id
JWT_ROLES_CLAIM=cognito:groups

# ===== WhatsApp (Meta) — vacío = envíos simulados (log) =====
WHATSAPP_VERIFY_TOKEN=sentrawash-verify
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=

# ===== Almacenamiento de fotos (AWS S3) =====
# Si AWS_S3_BUCKET está vacío, la subida de fotos queda inactiva y las órdenes
# se crean igual (sin foto). Las claves IAM deben tener solo PutObject/GetObject
# sobre este bucket. Si dejas las claves vacías, se usa la cadena de credenciales
# por defecto de AWS (rol de instancia).
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
